rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // An admin is any signed-in user with a verified email listed in /admins.
    // Admins are added/removed from the admin portal by existing admins.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    match /submissions/{docId} {
      allow create: if
        // Whitelist allowed fields — reject any extra fields
        request.resource.data.keys().hasOnly(['name', 'email', 'company', 'service', 'submittedAt', 'status']) &&
        // Required fields must be present
        request.resource.data.keys().hasAll(['name', 'email', 'service', 'submittedAt', 'status']) &&
        // name: non-empty string, max 200 chars
        request.resource.data.name is string &&
        request.resource.data.name.size() >= 1 &&
        request.resource.data.name.size() <= 200 &&
        // email: string, basic length bounds
        request.resource.data.email is string &&
        request.resource.data.email.size() >= 5 &&
        request.resource.data.email.size() <= 254 &&
        request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$') &&
        // service: non-empty string, max 5000 chars
        request.resource.data['service'] is string &&
        request.resource.data['service'].size() >= 1 &&
        request.resource.data['service'].size() <= 5000 &&
        // company: optional — if present must be a string under 200 chars
        (!('company' in request.resource.data) ||
          (request.resource.data.company is string &&
           request.resource.data.company.size() <= 200)) &&
        // submittedAt must be a server timestamp
        request.resource.data.submittedAt is timestamp &&
        request.resource.data.submittedAt == request.time &&
        // status must always be 'new' — clients cannot set other statuses
        request.resource.data.status == 'new';

      // Admins (from the portal) may read submissions and update only the
      // status / notes fields — the submitter's own data stays tamper-proof.
      allow read: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'adminNotes', 'updatedAt'])
        && request.resource.data.status in ['new', 'contacted', 'closed']
        // updatedAt must be the server timestamp — clients can't backdate it
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.updatedAt == request.time
        // adminNotes, when present, must be a bounded string
        && (!('adminNotes' in request.resource.data)
            || (request.resource.data.adminNotes is string
                && request.resource.data.adminNotes.size() <= 5000));
      allow delete: if false;
    }

    // Admin allowlist. A signed-in user may read ONLY their own doc — even before their
    // email is verified — so the app can route them to the "verify email" step. Accounts
    // and this allowlist are managed by IT on the terminal (Admin SDK bypasses these
    // rules); clients can never list, add, or remove entries. The email-verified check
    // in isAdmin() also prevents gaining access by signing up as an allowlisted address
    // you don't actually control.
    match /admins/{adminEmail} {
      allow get: if request.auth != null && request.auth.token.email == adminEmail;
      allow list, create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
